<% content_for :topbar_content do %>
  <div class="flex flex-col justify-between w-full gap-4 py-4 md:items-center md:flex-row md:gap-0">
    <div>
      <h1 class="font-semibold text-secondary-900 h4"><%= t('project.form.new_project') %></h1>
      <p class="text-secondary-900"><%= t('project.form.new_project_subtitle') %></p>
    </div>
  </div>
<% end %>
<div class="min-h-full">
  <div class="max-w-7xl">
    <div class="p-4 bg-white rounded-t-lg shadow ">
      <%= render "shared/credits/title" %>

      <%= form_with model: @credit,
        url: credits_path,
        method: :post,
        html: { class: 'form', id: 'investments-form' } do |f| %>
        <div class="py-4">
          <div data-controller="form-table-nested-fields">
          <%= render 'shared/errors', object: @project %>

            <div class="form-table-wrapper">
              <div class="form-table-container">
                <table class="form-table form-table--vertical">
                  <thead>
                    <tr>
                      <th>Parametar</th>
                      <th>Vrijednost</th>
                    </tr>
                  </thead>
                  <tbody id="investment-fields-wrapper" data-controller="excel-formulas" data-step="<%= step %>">
                    <%= f.fields_for :credits do |credit_fields| %>
                      <%= render 'credit_fields', f: credit_fields %>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="flex justify-end mt-6">
              <%= button_tag type: 'submit', class: 'btn btn-primary btn-lg' do %>
                <%= phosphor_icon "floppy-disk" %>
                <%= t("project.save_table") %>
              <% end %>
            </div>
          </div>
        </div>
        <div class="py-4">
          <div data-controller="form-table-nested-fields">
            <div class="overflow-x-auto overflow-hidden rounded-lg bg-white shadow-sm relative form-table-border-overlay">
              <table class="form-table form-table--credit-months">
                <thead>
                  <tr>
                    <th> </th>
                    <th> </th>
                    <th> </th>
                    <th> </th>
                    <th> </th>
                    <th> </th>
                    <th> <%= tf("credit.months.date") %> </th>
                    <th> <%= tf("credit.months.month") %> </th>
                    <th> <%= tf("credit.months.installment") %> </th>
                    <th> <%= tf("credit.months.principal") %> </th>
                    <th> <%= tf("credit.months.interest") %> </th>
                    <th> <%= tf("credit.months.debt_rest") %> </th>
                  </tr>
                </thead>
                <tbody data-credit-months>
                  <tr data-credit-permanent>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td data-credit-rest></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <div class="py-4">
          <div data-controller="form-table-nested-fields">
            <div class="overflow-x-auto overflow-hidden rounded-lg bg-white shadow-sm relative form-table-border-overlay">
              <table class="form-table form-table--credit-totals">
                <thead>
                  <tr>
                    <th> </th>
                    <th> <%= tf("credit.months.installment") %> </th>
                    <th> <%= tf("credit.months.principal") %> </th>
                    <th> <%= tf("credit.months.interest") %> </th>
                    <th> <%= tf("credit.months.debt_rest") %> </th>
                  </tr>
                </thead>
                <tbody data-credit-totals>
                  <tr data-credit-permanent>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td data-credit-rest></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
