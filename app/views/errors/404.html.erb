<div class="grid min-h-screen px-6 py-24 bg-gray-50 place-items-center sm:py-32 lg:px-8">
  <div class="text-center max-w-xl">
    <!-- Error Code -->
    <p class="text-4xl font-extrabold text-red-600 animate-pulse sm:text-6xl">
      404
    </p>

    <!-- Main Message -->
    <h1 class="mt-6 text-3xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      <%= t('error_page.text404') %>
    </h1>

    <!-- Subtext -->
    <p class="mt-4 text-base text-gray-600 sm:text-lg leading-relaxed">
      <%= t('error_page.error_bottom_text') %>
    </p>

    <!-- Homepage Button -->
    <div class="mt-8 flex justify-center">
      <%= link_to t('error_page.our_homepage'), root_path, class: "inline-block px-6 py-3 font-semibold text-white bg-red-600 rounded-lg shadow-lg hover:bg-red-700 hover:scale-105 transform transition duration-300" %>
    </div>
  </div>
</div>
