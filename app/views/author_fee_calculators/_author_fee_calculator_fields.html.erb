<tr>
  <td>
    <div class="form-table-label">
      <%= tf("author_fee_calculator.amount_in_cent") %>
    </div>
  </td>

  <td>
    <div class="form-table-cell">
      <%= money_field f, :amount_in_cent, class: 'form-table-input', min: 0,
        data: {
          "amount_in_cent" => true,
          "amount_in_cent_input" => true, action: "input->author-fee-calculator#authorFeeCalculate"
        } %>
    </div>
  </td>
</tr>

<tr>
  <td>
    <div class="form-table-label">
      <%= tf("author_fee_calculator.contract_type") %>
    </div>
  </td>

  <td>
    <div class="form-table-cell">
      <% AuthorFeeCalculator::FEE_TYPES.each do |value| %>
        <% key = value.tr('-', '_') %>
        <% id  = "#{f.object_name}_contract_type_#{key}" %>

        <label for="<%= id %>"
               class="mb-3 flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-slate-300 hover:bg-slate-50">
               <%= f.radio_button :contract_type, value,
                 id: id,
                 data: {
                   contract_type_input: true, 
                   action: "input->author-fee-calculator#authorFeeCalculate"
                 },
                 class: "h-5 w-5 text-primary-600 focus:ring-2 focus:ring-primary-500" %>

               <span class="text-sm font-medium text-slate-900">
                 <%= tf("author_fee_calculator.contract_types.#{key}") %>
               </span>
        </label>
      <% end %>
    </div>
  </td>
</tr>

<tr>
  <td>
    <div class="form-table-label">
      <%= tf("author_fee_calculator.city_tax_rate_id") %>
    </div>
  </td>

  <td>
    <div class="form-table-cell">
      <div class="relative">
        <input
            type="text"
            class="form-table-input"
            placeholder="<%= t('search') %>..."
            autocomplete="off"
            data-author-fee-calculator-target="citySearch"
            />

            <%= f.hidden_field :city_tax_rate_id,
              data: { author_fee_calculator_target: "cityTaxRateId" } %>
      </div>
    </div>
  </td>
</tr>


<tr>
  <td>
    <div class="form-table-label">
      <%= tf("author_fee_calculator.calculation_type") %>
    </div>
  </td>

  <td>
    <%= render "shared/calculation_method_field", f: f %>
  </td>
</tr>


