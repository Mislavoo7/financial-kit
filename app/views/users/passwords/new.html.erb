<div class="devise-card">
  <h2 class="devise-title"><%= t("devise.passwords.new.forgot_your_password") %></h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "devise-form" }) do |f| %>
    <%= render "users/shared/error_messages", resource: resource %>

    <div class="devise-field">
      <%= f.label :email, class: "devise-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "devise-input" %>
    </div>

    <div class="devise-actions">
      <%= f.submit t("devise.passwords.new.send_me_reset_password_instructions"), class: "devise-button" %>
    </div>
  <% end %>

  <%= render "users/shared/links" %>
</div>
