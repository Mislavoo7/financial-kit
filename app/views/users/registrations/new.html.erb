<div class="card">
  <div class="card-title">
    <%= image_tag "logo.png", class: "mx-auto w-auto", alt: t("common.logo_alt") %>
    <h2 class="mt-10 text-center text-2xl/9 font-bold tracking-tight text-gray-900">
      <%= t("devise.registrations.sign_up") %>
    </h2>
  </div>

  <div class="form-container">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="form-body">
        <%= render "admins/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, class: "label" %>
          <div class="mt-2">
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input" %>
          </div>
        </div>

        <div>
          <%= f.label :password, class: "label" %>

          <% if @minimum_password_length %>
            <div class="help-text">
              <%= t("devise.registrations.min_char", num: @minimum_password_length) %>
            </div>
          <% end %>

          <div class="mt-2">
            <%= f.password_field :password, autocomplete: "new-password", class: "input" %>
          </div>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "label" %>
          <div class="mt-2">
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input" %>
          </div>
        </div>

        <div>
          <%= f.submit t("devise.registrations.sign_up_button"), class: "button is-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
