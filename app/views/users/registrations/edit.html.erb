<div class="card">
  <div class="card-title">
    <h2 class="text-center text-2xl font-bold tracking-tight text-gray-900">
      <%= t("devise.registrations.edit_title", resource: resource_name.to_s.humanize) %>
    </h2>
  </div>

  <div class="form-container">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <div class="form-body">
        <%= render "users/shared/error_messages", resource: resource %>

        <div class="field">
          <%= f.label :email, class: "label" %>
          <div class="mt-2">
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input" %>
          </div>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="help-text">
            <%= t("devise.registrations.currently_waiting_confirmation_for", email: resource.unconfirmed_email) %>
          </div>
        <% end %>

        <div class="field">
          <%= f.label :password, class: "label" %>
          <div class="help-text">
            <%= t("devise.registrations.leave_blank_if_you_dont_want_to_change_it") %>
          </div>
          <div class="mt-2">
            <%= f.password_field :password, autocomplete: "new-password", class: "input" %>
          </div>

          <% if @minimum_password_length %>
            <div class="help-text">
              <%= t("devise.registrations.characters_minimum", count: @minimum_password_length) %>
            </div>
          <% end %>
        </div>

        <div class="field">
          <%= f.label :password_confirmation, class: "label" %>
          <div class="mt-2">
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input" %>
          </div>
        </div>

        <div class="field">
          <%= f.label :current_password, class: "label" %>
          <div class="help-text">
            <%= t("devise.registrations.we_need_your_current_password_to_confirm_changes") %>
          </div>
          <div class="mt-2">
            <%= f.password_field :current_password, autocomplete: "current-password", class: "input" %>
          </div>
        </div>

        <div class="actions">
          <%= f.submit t("devise.registrations.update_button"), class: "button is-primary" %>
        </div>
      </div>
    <% end %>

    <div class="mt-8 rounded-lg border border-gray-200 p-4">
      <h3 class="text-sm font-semibold text-gray-900">
        <%= t("devise.registrations.cancel_account_title") %>
      </h3>

      <p class="mt-1 text-sm text-gray-600">
        <%= t("devise.registrations.unhappy") %>
      </p>

      <div class="mt-4">
        <%= button_to(
          t("devise.registrations.cancel_account_button"),
          registration_path(resource_name),
          method: :delete,
          data: { confirm: t("devise.registrations.are_you_sure"), turbo_confirm: t("devise.registrations.are_you_sure") },
          class: "button"
        ) %>
      </div>

      <div class="mt-4 text-center text-sm">
        <%= link_to t("common.back"), :back, class: "text-indigo-600 hover:underline" %>
      </div>
    </div>
  </div>
</div>
