<tr>
  <td>
    <div class="form-table-label">
      <%= tf("salary_calculator.amount_in_cent") %>
    </div>
  </td>

  <td>
    <div class="form-table-cell">
      <%= money_field f, :amount_in_cent, class: 'form-table-input', min: 0,
        data: {
          "amount_in_cent" => true,
          "amount_in_cent_input" => true, action: "input->salary-calculator#salaryCalculate"
        } %>
    </div>
  </td>
</tr>

<tr>
  <td>
    <div class="form-table-label">
      <%= tf("salary_calculator.kids_num") %>
    </div>
  </td>

  <td>
    <div class="form-table-cell">
      <%= f.number_field :kids_num, class: 'form-table-input' , step: 1, min: 0, placeholder: '0', requred: true , data: {
        kids_num_input: true, action: "input->salary-calculator#salaryCalculate"
      } %>
    </div>
  </td>
</tr>

<tr>
  <td>
    <div class="form-table-label">
      <%= tf("salary_calculator.dependents_num") %>
    </div>
  </td>

  <td>
    <div class="form-table-cell">
      <%= f.number_field :dependents_num, class: 'form-table-input', step: 1, min: 0 , placeholder: '0', requred: true , data: {
        dependents_num_input: true, action: "input->salary-calculator#salaryCalculate"
      } %>
    </div>
  </td>
</tr>

<tr>
  <td>
    <div class="form-table-label">
      <%= tf("salary_calculator.disability") %>
    </div>
  </td>

  <td>
    <div class="form-table-cell">
      <% SalaryCalculator::DISABILITY_TYPE.each do |value| %>
        <% key = value.tr('-', '_') %>
        <% id  = "#{f.object_name}_disability_#{key}" %>

        <label for="<%= id %>"
               class="mb-3 flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-slate-300 hover:bg-slate-50">
               <%= f.radio_button :disability, value,
                 id: id,
                 data: {
                   disability_input: true, 
                   action: "input->salary-calculator#salaryCalculate"
                 },
                 class: "h-5 w-5 text-primary-600 focus:ring-2 focus:ring-primary-500" %>

               <span class="text-sm font-medium text-slate-900">
                 <%= tf("salary_calculator.disabilities.#{key}") %>
               </span>
        </label>
      <% end %>
    </div>
  </td>
</tr>

<tr>
  <td>
    <div class="form-table-label">
      <%= tf("salary_calculator.city_tax_rate_id") %>
    </div>
  </td>

  <td>
    <div class="form-table-cell">
      <div class="relative">
        <input
            type="text"
            class="form-table-input"
            placeholder="<%= t('search') %>..."
            autocomplete="off"
            data-salary-calculator-target="citySearch"
            />

            <%= f.hidden_field :city_tax_rate_id,
              data: { salary_calculator_target: "cityTaxRateId" } %>
      </div>
    </div>
  </td>
</tr>


<tr>
  <td>
    <div class="form-table-label">
      <%= tf("salary_calculator.calculation_type") %>
    </div>
  </td>

  <td>
    <%= render "shared/calculation_method_field", f: f, 
      action: "input->salary-calculator#salaryCalculate"
      targetName: "salary_calculator"
    %>
  </td>
</tr>


