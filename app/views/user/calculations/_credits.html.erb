<% @credits.each do |credit| %>
  <div id="<%= dom_id(credit) %>" class="bg-white border border-secondary-200 rounded-xl shadow-sm hover:shadow-md transition-shadow p-4 flex flex-col gap-3">

    <div class="flex flex-col gap-1 text-sm text-gray-700">
      <div class="flex justify-between">
        <span class="text-gray-400 text-xs uppercase tracking-wide"><%= t("calculator.credit.title") %></span>
        <span class="font-semibold text-gray-800"><%= credit.humanize_amount_in_cent %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-400 text-xs uppercase tracking-wide"><%= tf("credit.interest_ratio") %></span>
        <span class="font-semibold text-gray-800"><%= credit.humanize_interest_ratio %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-400 text-xs uppercase tracking-wide"><%= tf("credit.number_of_installments") %></span>
        <span class="font-semibold text-gray-800"><%= credit.number_of_installments %></span>
      </div>
    </div>

    <div class="flex justify-between items-center pt-2 border-t border-secondary-100">
      <%= link_to edit_user_credit_path(credit), class: "text-xs text-primary-600 hover:text-primary-800 font-medium flex items-center gap-1" do %>
        <%= phosphor_icon "pencil-simple", class: "w-4 h-4" %>
        <%= t("shared.edit") %>
      <% end %>

      <%= link_to user_credit_path(credit),
        method: :delete,
        remote: true,
        data: { confirm: t("are_you_sure") },
        class: "text-xs text-gray-400 hover:text-red-500 font-medium flex items-center gap-1 transition-colors" do %>
        <%= phosphor_icon "trash", class: "w-4 h-4" %>
        <%= t("shared.delete") %>
      <% end %>
    </div>

  </div>
<% end %>
