<% @credits.each do |credit| %>
  <div id="<%= dom_id(credit) %>" class="credit-card">

    <div class="credit-meta">
      <div class="credit-row">
        <span class="credit-label"><%= t("calculator.credit.title") %></span>
        <span class="credit-value"><%= credit.humanize_amount_in_cent %></span>
      </div>

      <div class="credit-row">
        <span class="credit-label"><%= tf("credit.interest_ratio") %></span>
        <span class="credit-value"><%= credit.humanize_interest_ratio %></span>
      </div>

      <div class="credit-row">
        <span class="credit-label"><%= tf("credit.number_of_installments") %></span>
        <span class="credit-value"><%= credit.number_of_installments %></span>
      </div>
    </div>

    <div class="credit-actions">
      <%= link_to edit_user_credit_path(credit), class: "credit-action-edit" do %>
        <%= phosphor_icon "pencil-simple", class: "credit-action-icon" %>
        <%= t("shared.edit") %>
      <% end %>

      <%= link_to user_credit_path(credit),
        method: :delete,
        remote: true,
        data: { confirm: t("are_you_sure") },
        class: "credit-action-delete" do %>
        <%= phosphor_icon "trash", class: "credit-action-icon" %>
        <%= t("shared.delete") %>
      <% end %>
    </div>

  </div>
<% end %>
