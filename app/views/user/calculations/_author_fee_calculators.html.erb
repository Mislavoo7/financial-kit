<% @author_fee_calculators.each do |author_fee_calculator| %>
  <div id="<%= dom_id(author_fee_calculator) %>" class="credit-card">

    <div class="credit-meta">
      <div class="credit-row">
        <span class="credit-label"> <strong> <u> <%= t("calculators.author.title") %> </u> </strong></span>
      </div>

      <div class="credit-row">
        <span class="credit-label"><%= tf("author_fee_calculator.brut") %></span>
        <span class="credit-value"><%= author_fee_calculator.humanize_brut_in_cent %></span>
      </div>

      <div class="credit-row">
        <span class="credit-label"><%= tf("author_fee_calculator.net") %></span>
        <span class="credit-value"><%= author_fee_calculator.humanize_net_in_cent %></span>
      </div>

      <div class="credit-row">
        <span class="credit-label"><%= tf("author_fee_calculator.fee_type") %></span>
        <span class="credit-value"><%= tf("author_fee_calculator.fee_types.#{author_fee_calculator.fee_type.gsub("-", "_")}") %></span>
      </div>

      <div class="credit-row">
        <span class="credit-label"><%= t("created_at") %></span>
        <span class="credit-value"><%= author_fee_calculator.created_at.strftime("%d.%m.%Y") %></span>
      </div>
    </div>

    <div class="credit-actions">
      <%= link_to edit_user_author_fee_calculator_path(author_fee_calculator), class: "credit-action-edit" do %>
        <%= phosphor_icon "pencil-simple", class: "credit-action-icon" %>
        <%= t("shared.edit") %>
      <% end %>

      <%= link_to user_author_fee_calculator_path(author_fee_calculator),
        method: :delete,
        remote: true,
        data: { confirm: t("are_you_sure") },
        class: "credit-action-delete" do %>
        <%= phosphor_icon "trash", class: "credit-action-icon" %>
        <%= t("shared.delete") %>
      <% end %>
    </div>

  </div>
<% end %>
