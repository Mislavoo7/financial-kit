<%= form_with model: @service_contract_calculator,
  url: url,
  method: method,
  html: { class: 'form', id: 'investments-form' } do |f| %>

  <div
      data-controller="service-contract-calculator"
      data-service-contract-calculator-city-tax-rates-value="<%= @city_tax_rates %>"
      >

      <div class="py-4">
        <%= render 'shared/errors', object: @service_contract_calculator %>

        <div class="form-table-wrapper">
          <div class="form-table-container">
            <table class="form-table form-table--vertical">
              <thead>
                <tr>
                  <th><%= tf("service_contract_calculator.parametar") %></th>
                  <th><%= tf("service_contract_calculator.value") %></th>
                </tr>
              </thead>

              <tbody id="investment-fields-wrapper">
                <%= render 'service_contract_calculators/service_contract_calculator_fields', f: f %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <div class="py-4">
        <div class="overflow-x-auto overflow-hidden rounded-lg bg-white shadow-sm relative form-table-border-overlay">
          <table class="form-table form-table--credit-totals">
            <thead>
              <tr>
                <th><%= tf("service_contract_calculator.parametar") %></th>
                <th><%= tf("service_contract_calculator.value") %></th>
              </tr>
            </thead>

            <tbody>
              <% ratio_items = %w[first_pillar second_pillar income_tax health_insurance] %>
              <% money_items = %w[brut first_pillar second_pillar total_pillar taxation_base income_tax_in_euro net health_insurance employer_to_pay] %>
              <% ["brut", "first_pillar", "second_pillar", "total_pillar", "income_tax", "taxation_base", "net", "health_insurance", "employer_to_pay"].each do |item| %>
                <tr>
                  <td><%= tf("service_contract_calculator#{item}") %></td>
                  <td>
                    <% formated_item = item.tr("_", "-") %>

                    <% if ratio_items.include?(item) %>
                      <span data-<%= formated_item %>-ratio>0</span> |
                      <span data-<%= formated_item %>>0</span>

                      <%= f.hidden_field "#{item}_ratio".to_sym, data: {
                        "#{formated_item}-ratio-hidden" => true
                      } %>

                    <%= f.hidden_field "#{item}_in_cent".to_sym, data: {
                      "#{formated_item}-hidden" => true
                    } %>

                    <% elsif money_items.include?(item) %>
                      <span data-<%= formated_item %>>0</span>
    
                      <%= f.hidden_field "#{item}_in_cent".to_sym, data: {
                        "#{formated_item}-hidden" => true
                      } %>
    
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>

          </table>
        </div>
      </div>

      <div class="calculator-save-floating">
        <%= button_tag type: "submit", class: "button is-primary calculator-save-floating__button" do %>
          <%= phosphor_icon "floppy-disk" %>
          <span>
            <%= t("save") %>
            <%= "#{t("and")} #{t("devise.registrations.sign_up_button").downcase}" unless current_user %>
          </span>
        <% end %>
      </div>
  </div>
<% end %>

